# Customer web app env. Copy to `.env.local` for dev.

# API origin — wrangler dev defaults to :8787.
NEXT_PUBLIC_API_URL=http://localhost:8787

# Cloudflare Turnstile site key (matches the SECRET in apps/api).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# (Optional) override the canonical site URL for SEO + emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
