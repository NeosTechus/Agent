# Vercel + pnpm monorepo fix: flatten node_modules so Next.js binaries
# resolve cleanly during Vercel's build (the default pnpm `.pnpm/` store
# layout breaks lstat() inside Vercel's container — see ENOENT errors on
# /vercel/path0/node_modules/.pnpm/next@.../...).
#
# This makes pnpm install behave more like npm/yarn (deps live directly
# under node_modules instead of being content-addressable), at the cost
# of some disk space. Worth it for build portability.
node-linker=hoisted
shamefully-hoist=true
